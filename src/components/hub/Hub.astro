---
import { SECTIONS, HUB } from '@/lib/nav';

const R = 128; // node distance from center (matches SVG viewBox units = px)
const deg = Math.PI / 180;
const nodes = SECTIONS.map((s) => ({
  ...s,
  dx: Math.round(Math.cos(s.angle * deg) * R),
  dy: Math.round(Math.sin(s.angle * deg) * R),
}));
---

<div class="hub">
  <svg class="hub__edges" viewBox="-180 -180 360 360" aria-hidden="true">
    {nodes.map((n) => <line x1="0" y1="0" x2={n.dx} y2={n.dy} />)}
  </svg>

  <div class="hnode hnode--hub">
    <span class="hnode__dot" style={`background:${HUB.color}`}></span>
    <span class="hnode__label">{HUB.label}</span>
  </div>

  {nodes.map((n) => (
    <a
      class="hnode"
      data-goto={n.id}
      href={`#${n.id}`}
      style={`--dx:${n.dx}px; --dy:${n.dy}px`}
      aria-label={n.label}
    >
      <span class="hnode__dot" style={`background:${n.color}`}></span>
      <span class="hnode__label">{n.label}</span>
    </a>
  ))}
</div>
