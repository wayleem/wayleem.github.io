---
import { CONTACT_LINKS } from '@/lib/nav';
const ext = (href: string) => href.startsWith('http');
---

<div class="room room--center">
  <div class="room__inner contact">
    <h1 class="room__title">contact</h1>
    <p class="contact__lede">say hi —</p>
    <ul class="contact__links">
      {CONTACT_LINKS.map((l) => (
        <li>
          <a
            href={l.href}
            target={ext(l.href) ? '_blank' : undefined}
            rel={ext(l.href) ? 'noopener me' : undefined}
          >
            {l.label}{ext(l.href) && <span aria-hidden="true"> ↗</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>
