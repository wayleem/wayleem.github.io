---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('writing')).filter((e) => !e.data.draft);
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${entry.data.title} — Wayleem`} description={entry.data.summary}>
  <main class="page">
    <a class="page__back" href="/?open=writing">← writing</a>
    <h1>{entry.data.title}</h1>
    <time class="meta mono" datetime={entry.data.date.toISOString()}>{fmt(entry.data.date)}</time>
    <div class="prose"><Content /></div>
  </main>
</BaseLayout>

<style>
  .meta { display: block; color: var(--text-dim); font-size: 0.85rem; margin: 0.25rem 0 2rem; }
</style>
