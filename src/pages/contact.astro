---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CONTACT_LINKS } from '@/lib/nav';
const ext = (href: string) => href.startsWith('http');
---

<BaseLayout title="Contact — Wayleem" description="Get in touch.">
  <main class="page">
    <a class="page__back" href="/#contact">← map</a>
    <h1>Contact</h1>
    <p class="lede">Say hi.</p>
    <ul class="links mono">
      {CONTACT_LINKS.map((l) => (
        <li>
          <a href={l.href} target={ext(l.href) ? '_blank' : undefined} rel={ext(l.href) ? 'noopener me' : undefined}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  .links { list-style: none; padding: 0; margin: 1.5rem 0 0; display: grid; gap: 0.6rem; font-size: 1.1rem; }
</style>
