# ---------------------------------------------------------------------------
# Copy to `.dev.vars` (Cloudflare local dev reads .dev.vars, KEY=value format).
# In production these are set as Cloudflare Worker secrets — NEVER commit real
# values. `.env` / `.dev.vars` are gitignored.
# ---------------------------------------------------------------------------

# Keystatic — GitHub mode (browser publishing). Created via Keystatic's GitHub
# App setup flow. Only repo collaborators can commit; see keystatic.config.ts.
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# Contact form — email delivery via Resend (MailChannels' free CF route is gone).
RESEND_API_KEY=
CONTACT_TO_EMAIL=wayleemh@gmail.com

# Cloudflare Turnstile — invisible spam protection on the contact form.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
